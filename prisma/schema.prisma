// Poke Deal - data model
// The dealer loop: value -> buy -> stock -> price -> list -> sell -> book profit.
// All monetary values are stored in GBP pence (integers) to avoid float drift.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────

/// A canonical card in the catalog. Card-agnostic on purpose so sports cards slot in later.
model Card {
  id       String   @id @default(cuid())
  game     Game     @default(POKEMON)
  language Language @default(EN)

  name     String
  setName  String
  setCode  String?
  number   String? // collector number within the set, e.g. "058/198"
  rarity   String?
  imageUrl String?

  // External catalog references, for adapter lookups.
  tcgApiId     String? @unique // pokemontcg.io id
  tcgDexId     String? @unique // tcgdex.net id
  cardmarketId String?

  inventory        InventoryItem[]
  comps            CompResult[]
  snapshots        PriceSnapshot[]
  watches          Watch[]
  dealSessionLines DealSessionLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([game, language])
  @@index([name])
  @@index([setName])
  @@index([setCode])
}

// ─────────────────────────────────────────────────────────────
// Inventory (the Fat Lava Ledger job, done properly)
// ─────────────────────────────────────────────────────────────

model InventoryItem {
  id     String @id @default(cuid())
  card   Card   @relation(fields: [cardId], references: [id])
  cardId String

  grade      Grade   @default(RAW)
  graderCert String? // PSA/BGS/CGC cert number when graded
  condition  String? // free-text for raw nuance ("NM", "light edgewear")
  quantity   Int     @default(1)

  costBasis    Int // GBP pence — what I paid, per unit
  acquiredFrom String? // source: "eBay", "card fair", "collection buy", etc.
  acquiredAt   DateTime @default(now())
  location     String? // bin / box / shelf reference

  status InventoryStatus @default(IN_STOCK)

  listings         Listing[]
  sales            Sale[]
  photos           CardPhoto[]
  ebayOrderImports EbayOrderImport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([cardId, grade])
}

model CardPhoto {
  id              String        @id @default(cuid())
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  inventoryItemId String
  url             String
  role            PhotoRole     @default(FRONT)
  origin          PhotoOrigin   @default(REAL)
  width           Int?
  height          Int?
  order           Int           @default(0)
  createdAt       DateTime      @default(now())

  @@index([inventoryItemId])
}

// ─────────────────────────────────────────────────────────────
// Listings (track across channels; automate eBay only)
// ─────────────────────────────────────────────────────────────

model Listing {
  id     String        @id @default(cuid())
  item   InventoryItem @relation(fields: [itemId], references: [id])
  itemId String

  channel Channel
  state   ListingState @default(DRAFT)

  title          String?
  description    String?
  suggestedPrice Int? // GBP pence — from the comp engine
  listPrice      Int? // GBP pence — what I actually listed at
  externalRef    String? // eBay listing/offer id etc.
  externalUrl    String?

  listedAt         DateTime?
  endedAt          DateTime?
  ebayOrderImports EbayOrderImport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channel, state])
}

// ─────────────────────────────────────────────────────────────
// Sales (book the profit)
// ─────────────────────────────────────────────────────────────

model Sale {
  id     String        @id @default(cuid())
  item   InventoryItem @relation(fields: [itemId], references: [id])
  itemId String

  channel   Channel
  salePrice Int // GBP pence — gross
  fees      Int      @default(0) // GBP pence — channel + payment fees
  postage   Int      @default(0) // GBP pence — cost to me, net of what buyer paid
  soldAt    DateTime @default(now())

  // realized profit = salePrice - fees - postage - (item.costBasis) ; computed in service layer
  createdAt       DateTime         @default(now())
  ebayOrderImport EbayOrderImport?

  @@index([soldAt])
}

model EbayOrderImport {
  id         String                @id @default(cuid())
  importKey  String                @unique
  orderId    String
  lineItemId String?
  sku        String?
  ebayItemId String?
  title      String?
  status     EbayOrderImportStatus @default(UNMATCHED)
  reason     String?

  item      InventoryItem? @relation(fields: [itemId], references: [id])
  itemId    String?
  listing   Listing?       @relation(fields: [listingId], references: [id])
  listingId String?
  sale      Sale?          @relation(fields: [saleId], references: [id])
  saleId    String?        @unique

  orderCreatedAt      DateTime?
  paidAt              DateTime?
  buyerPaidPence      Int?
  postageChargedPence Int?
  feesEstimatePence   Int?
  payload             Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([orderId])
  @@index([sku])
  @@index([itemId])
  @@index([listingId])
}

model Expense {
  id          String          @id @default(cuid())
  category    ExpenseCategory @default(OTHER)
  description String
  amount      Int // GBP pence — operating cost paid by the business
  spentAt     DateTime        @default(now())
  channel     Channel?
  source      String?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spentAt])
  @@index([category])
}

// ─────────────────────────────────────────────────────────────
// Deal sessions (binder / lot buying)
// ─────────────────────────────────────────────────────────────

model DealSession {
  id          String            @id @default(cuid())
  name        String
  status      DealSessionStatus @default(OPEN)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  completedAt DateTime?
  abandonedAt DateTime?
  paidPence   Int?

  lines DealSessionLine[]

  @@index([status])
  @@index([createdAt])
}

model DealSessionLine {
  id        String      @id @default(cuid())
  session   DealSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  card      Card?       @relation(fields: [cardId], references: [id])
  cardId    String?

  name     String
  setName  String?
  setCode  String?
  number   String?
  tcgApiId String?
  tcgDexId String?
  imageUrl String?
  grade    Grade   @default(RAW)

  headlinePence       Int
  confidence          String
  manualCheck         Boolean   @default(false)
  maxCashOfferPence   Int?
  maxTradeOfferPence  Int?
  dealerOfferPence    Int?
  netProceedsPence    Int?
  expectedProfitPence Int?
  sampleSize          Int       @default(0)
  windowDays          Int       @default(0)
  compSource          String?
  compAsOf            DateTime?

  addedAt DateTime @default(now())

  @@index([sessionId])
  @@index([cardId])
}

// ─────────────────────────────────────────────────────────────
// Market data captured over time
// ─────────────────────────────────────────────────────────────

/// A cleaned comp result, persisted for history/audit. Mirrors lib/comps CompResult.
model CompResult {
  id     String @id @default(cuid())
  card   Card   @relation(fields: [cardId], references: [id])
  cardId String

  grade    Grade
  source   String // adapter name, e.g. "pokemon-price-tracker"
  currency String @default("GBP")

  medianPence     Int
  meanPence       Int
  lowPence        Int
  highPence       Int
  sampleSize      Int
  windowDays      Int
  trendPct        Float?
  outliersRemoved Int    @default(0)

  asOf      DateTime
  createdAt DateTime @default(now())

  @@index([cardId, grade, asOf])
}

/// Daily snapshot of stock value, so portfolio/trend history builds itself.
model PriceSnapshot {
  id          String   @id @default(cuid())
  card        Card     @relation(fields: [cardId], references: [id])
  cardId      String
  grade       Grade
  marketPence Int // GBP pence — the headline comp value on this day
  takenAt     DateTime @default(now())

  @@unique([cardId, grade, takenAt])
  @@index([takenAt])
}

model CronRun {
  id         String        @id @default(cuid())
  job        String
  runKey     String
  status     CronRunStatus @default(RUNNING)
  startedAt  DateTime      @default(now())
  finishedAt DateTime?
  details    Json?
  error      String?
  createdAt  DateTime      @default(now())

  @@unique([job, runKey])
  @@index([job, startedAt])
  @@index([status])
}

model FxRate {
  id        String   @id @default(cuid())
  quote     String
  perGbp    Float
  asOf      DateTime
  provider  String
  fetchedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([quote, asOf])
  @@index([asOf])
  @@index([fetchedAt])
}

// ─────────────────────────────────────────────────────────────
// Alerts / sourcing
// ─────────────────────────────────────────────────────────────

model Watch {
  id          String   @id @default(cuid())
  card        Card     @relation(fields: [cardId], references: [id])
  cardId      String
  grade       Grade    @default(RAW)
  targetPence Int // notify when market dips below this
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  alerts Alert[]

  @@index([active])
}

model Alert {
  id        String    @id @default(cuid())
  watch     Watch     @relation(fields: [watchId], references: [id])
  watchId   String
  kind      AlertKind
  message   String
  pence     Int?
  firedAt   DateTime  @default(now())
  delivered Boolean   @default(false)

  @@index([delivered])
}

model AppAlert {
  id        String       @id @default(cuid())
  kind      AppAlertKind
  title     String
  message   String
  pence     Int?
  href      String?
  sourceKey String?      @unique
  delivered Boolean      @default(false)
  readAt    DateTime?
  createdAt DateTime     @default(now())

  @@index([kind])
  @@index([readAt, createdAt])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum Game {
  POKEMON
  SOCCER // reserved for future (see brief §9)
}

enum Language {
  EN
  JP
}

enum Grade {
  RAW
  PSA_1
  PSA_2
  PSA_3
  PSA_4
  PSA_5
  PSA_6
  PSA_7
  PSA_8
  PSA_9
  PSA_10
  BGS_1
  BGS_1_5
  BGS_2
  BGS_2_5
  BGS_3
  BGS_3_5
  BGS_4
  BGS_4_5
  BGS_5
  BGS_5_5
  BGS_6
  BGS_6_5
  BGS_7
  BGS_7_5
  BGS_8
  BGS_8_5
  BGS_9
  BGS_9_5
  BGS_10
  CGC_1
  CGC_1_5
  CGC_2
  CGC_2_5
  CGC_3
  CGC_3_5
  CGC_4
  CGC_4_5
  CGC_5
  CGC_5_5
  CGC_6
  CGC_6_5
  CGC_7
  CGC_7_5
  CGC_8
  CGC_8_5
  CGC_9
  CGC_9_5
  CGC_10
  ACE_9
  ACE_10
}

enum InventoryStatus {
  IN_STOCK
  LISTED
  SOLD
  RESERVED
}

enum DealSessionStatus {
  OPEN
  COMPLETED
  ABANDONED
}

enum Channel {
  EBAY
  CARDMARKET
  VINTED
  IN_PERSON
}

enum ListingState {
  DRAFT
  ACTIVE
  SOLD
  ENDED
}

enum PhotoRole {
  FRONT
  BACK
  SLAB
  EXTRA
}

enum PhotoOrigin {
  REAL
  CATALOG
}

enum ExpenseCategory {
  SUPPLIES
  POSTAGE
  GRADING
  TABLE_FEE
  TRAVEL
  PLATFORM
  OTHER
}

enum AlertKind {
  PRICE_DROP // watchlist target hit (sourcing)
  REPRICE // owned stock should be repriced
}

enum AppAlertKind {
  PRICE_DROP
  REPRICE
  CRON_FAILURE
  EBAY_SALE
}

enum EbayOrderImportStatus {
  MATCHED
  UNMATCHED
  SKIPPED
}

enum CronRunStatus {
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}
