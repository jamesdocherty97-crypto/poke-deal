// Poke Deal - data model
// The dealer loop: value -> buy -> stock -> price -> list -> sell -> book profit.
// All monetary values are stored in GBP pence (integers) to avoid float drift.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Runtime traffic uses the Neon pooler. Prisma migrations use the direct
  // endpoint so DDL and advisory locks are not routed through PgBouncer.
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────

/// A canonical card in the catalog. Card-agnostic on purpose so sports cards slot in later.
model Card {
  id       String   @id @default(cuid())
  game     Game     @default(POKEMON)
  language Language @default(EN)

  name            String
  setName         String
  setCode         String?
  number          String? // collector number within the set, e.g. "058/198"
  rarity          String?
  imageUrl        String?
  displayImageUrl String? // display-only fallback art; never used as listing/photo-pipeline catalog art

  // External catalog references, for adapter lookups.
  tcgApiId     String? @unique // pokemontcg.io id
  tcgDexId     String? @unique // tcgdex.net id
  cardmarketId String?
  edition      String? // UNLIMITED, FIRST_EDITION, SHADOWLESS, STAFF, PRERELEASE
  finish       String? // NORMAL, HOLO, REVERSE_HOLO

  inventory        InventoryItem[]
  comps            CompResult[]
  checkedComps     CheckedComp[]
  snapshots        PriceSnapshot[]
  watches          Watch[]
  dealSessionLines DealSessionLine[]
  scanEvents       ScanEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([game, language])
  @@index([name])
  @@index([setName])
  @@index([setCode])
  @@index([cardmarketId])
  @@index([game, language, setName, number, edition, finish], map: "Card_print_identity_idx")
}

// ─────────────────────────────────────────────────────────────
// Inventory (the Fat Lava Ledger job, done properly)
// ─────────────────────────────────────────────────────────────

model InventoryItem {
  id     String @id @default(cuid())
  card   Card   @relation(fields: [cardId], references: [id])
  cardId String

  grade      Grade   @default(RAW)
  graderCert String? // PSA/BGS/CGC cert number when graded
  condition  String? // free-text for raw nuance ("NM", "light edgewear")
  quantity   Int     @default(1)

  costBasis    Int // GBP pence — what I paid, per unit
  acquiredFrom String? // source: "eBay", "card fair", "collection buy", etc.
  acquiredAt   DateTime @default(now())
  location     String? // bin / box / shelf reference

  status           InventoryStatus @default(IN_STOCK)
  clientMutationId String?         @unique

  listings         Listing[]
  sales            Sale[]
  photos           CardPhoto[]
  ebayOrderImports EbayOrderImport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([cardId, grade])
  @@index([status, updatedAt])
}

model CardPhoto {
  id              String        @id @default(cuid())
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  inventoryItemId String
  url             String
  role            PhotoRole     @default(FRONT)
  origin          PhotoOrigin   @default(REAL)
  width           Int?
  height          Int?
  order           Int           @default(0)
  createdAt       DateTime      @default(now())

  @@index([inventoryItemId])
}

// ─────────────────────────────────────────────────────────────
// Listings (track across channels; automate eBay only)
// ─────────────────────────────────────────────────────────────

model Listing {
  id     String        @id @default(cuid())
  item   InventoryItem @relation(fields: [itemId], references: [id])
  itemId String

  channel Channel
  state   ListingState @default(DRAFT)

  title           String?
  titleCustomized Boolean @default(false)
  description    String?
  suggestedPrice Int? // GBP pence — from the comp engine
  listPrice      Int? // GBP pence — what I actually listed at
  externalRef    String? // eBay listing/offer id etc.
  externalUrl    String?

  listedAt         DateTime?
  endedAt          DateTime?
  ebayOfferId      String?
  offerSyncedAt    DateTime?
  offerSyncedPrice Int?
  ebayOrderImports EbayOrderImport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channel, state])
  @@index([itemId, state])
}

// ─────────────────────────────────────────────────────────────
// Sales (book the profit)
// ─────────────────────────────────────────────────────────────

model Sale {
  id     String        @id @default(cuid())
  item   InventoryItem @relation(fields: [itemId], references: [id])
  itemId String

  channel          Channel
  salePrice        Int // GBP pence — gross
  fees             Int      @default(0) // GBP pence — channel + payment fees
  postage          Int      @default(0) // GBP pence — cost to me, net of what buyer paid
  soldAt           DateTime @default(now())
  clientMutationId String?
  mutationIndex    Int      @default(0)

  // realized profit = salePrice - fees - postage - (item.costBasis) ; computed in service layer
  createdAt       DateTime         @default(now())
  ebayOrderImport EbayOrderImport?

  @@unique([clientMutationId, mutationIndex])
  @@index([soldAt])
  @@index([itemId, soldAt])
}

model EbayOrderImport {
  id         String                @id @default(cuid())
  importKey  String                @unique
  orderId    String
  lineItemId String?
  sku        String?
  ebayItemId String?
  title      String?
  status     EbayOrderImportStatus @default(UNMATCHED)
  reason     String?

  item      InventoryItem? @relation(fields: [itemId], references: [id])
  itemId    String?
  listing   Listing?       @relation(fields: [listingId], references: [id])
  listingId String?
  sale      Sale?          @relation(fields: [saleId], references: [id])
  saleId    String?        @unique

  orderCreatedAt      DateTime?
  paidAt              DateTime?
  buyerPaidPence      Int?
  postageChargedPence Int?
  feesEstimatePence   Int?
  payload             Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([orderId])
  @@index([sku])
  @@index([itemId])
  @@index([listingId])
}

model EbayCredential {
  id                     String    @id @default(cuid())
  key                    String    @unique @default("default")
  env                    String
  marketplaceId          String
  refreshTokenCiphertext String
  refreshTokenIv         String
  refreshTokenTag        String
  refreshTokenExpiresAt  DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  lastValidatedAt        DateTime?

  @@index([updatedAt])
}

model Expense {
  id          String          @id @default(cuid())
  category    ExpenseCategory @default(OTHER)
  description String
  amount      Int // GBP pence — operating cost paid by the business
  spentAt     DateTime        @default(now())
  channel     Channel?
  source      String?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spentAt])
  @@index([category])
}

// ─────────────────────────────────────────────────────────────
// Deal sessions (binder / lot buying)
// ─────────────────────────────────────────────────────────────

model DealSession {
  id          String            @id @default(cuid())
  name        String
  status      DealSessionStatus @default(OPEN)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  completedAt DateTime?
  abandonedAt DateTime?
  paidPence   Int?

  lines DealSessionLine[]

  @@index([status])
  @@index([createdAt])
}

model DealSessionLine {
  id        String      @id @default(cuid())
  session   DealSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  card      Card?       @relation(fields: [cardId], references: [id])
  cardId    String?

  name     String
  setName  String?
  setCode  String?
  number   String?
  tcgApiId String?
  tcgDexId String?
  cardmarketId String?
  language Language @default(EN)
  edition String?
  finish String?
  imageUrl String?
  grade    Grade   @default(RAW)

  headlinePence       Int
  confidence          String
  manualCheck         Boolean   @default(false)
  maxCashOfferPence   Int?
  maxTradeOfferPence  Int?
  dealerOfferPence    Int?
  netProceedsPence    Int?
  expectedProfitPence Int?
  sampleSize          Int       @default(0)
  windowDays          Int       @default(0)
  compSource          String?
  compAsOf            DateTime?

  addedAt DateTime @default(now())

  @@index([sessionId])
  @@index([cardId])
}

// ─────────────────────────────────────────────────────────────
// Market data captured over time
// ─────────────────────────────────────────────────────────────

/// A cleaned comp result, persisted for history/audit. Mirrors lib/comps CompResult.
model CompResult {
  id     String @id @default(cuid())
  card   Card   @relation(fields: [cardId], references: [id])
  cardId String

  grade    Grade
  condition String? // exact RAW condition bucket used for this lookup; null for legacy/graded rows
  source   String // adapter name, e.g. "pokemon-price-tracker"
  currency String @default("GBP")

  medianPence     Int
  meanPence       Int
  lowPence        Int
  highPence       Int
  sampleSize      Int
  windowDays      Int
  trendPct        Float?
  outliersRemoved Int    @default(0)

  asOf      DateTime
  createdAt DateTime @default(now())

  // Durable manual-check worklist metadata. The valuation evidence remains
  // append-only; only the resolution fields are updated by the review API.
  confidence     String?
  manualCheck    Boolean   @default(false)
  reasons        Json?
  receipt        Json?
  resolvedAt     DateTime?
  resolution     String?
  resolutionNote String?
  reviewRequestedAt DateTime?
  reviewExpiresAt   DateTime?

  @@index([cardId, grade, asOf])
  @@index([cardId, grade, createdAt])
  @@index([cardId, grade, condition, createdAt])
  @@index([manualCheck, resolvedAt, createdAt])
  @@index([reviewRequestedAt, reviewExpiresAt])
}

/// Dealer-observed comps logged after manually checking sold listings.
/// These are first-class evidence, not a single mutable override.
model CheckedComp {
  id     String @id @default(cuid())
  card   Card   @relation(fields: [cardId], references: [id])
  cardId String

  grade      Grade
  pricePence Int
  soldDate   DateTime
  platform   String   @default("ebay-uk")
  condition  String?  // NM/LP/MP/HP/DMG for RAW; null for graded or legacy rows
  priceBasis String   @default("UNKNOWN") // ITEM_PRICE qualifies; buyer totals/hidden offers do not
  note       String?
  sourceUrl  String?
  // Active listing IDs are unique through the partial index created by the
  // checked-comp void migration. Prisma cannot express partial indexes.
  sourceListingId String? // platform-prefixed immutable listing id; search URLs never qualify
  voidedAt   DateTime?
  voidReason String?

  createdAt DateTime @default(now())

  @@index([cardId, grade, soldDate])
  @@index([cardId, grade, condition, soldDate])
  @@index([createdAt])
}

/// Daily snapshot of stock value, so portfolio/trend history builds itself.
model PriceSnapshot {
  id          String   @id @default(cuid())
  card        Card     @relation(fields: [cardId], references: [id])
  cardId      String
  grade       Grade
  marketPence Int // GBP pence — the headline comp value on this day
  takenAt     DateTime @default(now())

  @@unique([cardId, grade, takenAt])
  @@index([takenAt])
}

/// Append-only scan observations. Captures "dealer considered this card" even
/// when it was not bought, stocked, or comped.
model ScanEvent {
  id     String  @id @default(cuid())
  card   Card?   @relation(fields: [cardId], references: [id])
  cardId String?

  source      String    @default("gemini-scan")
  status      String
  name        String?
  setName     String?
  setCode     String?
  number      String?
  language    Language?
  edition     String?
  finish      String?
  tcgApiId    String?
  tcgDexId    String?
  cardmarketId String?
  grade       Grade?
  condition   String?
  marketplace Channel?
  model       String?
  raw         Json?

  // Operational/evaluation telemetry. `sessionHash` is a one-way HMAC and
  // never stores the caller's raw session token.
  latencyMs     Int?
  requestBytes  Int?
  inputKind     String?
  sessionHash   String?
  correctionKey String? @unique

  // A correction is a new append-only ScanEvent linked to the observation it
  // corrects. Existing model output is never overwritten.
  correctionOfId String?
  correctionOf   ScanEvent?  @relation("ScanCorrections", fields: [correctionOfId], references: [id])
  corrections    ScanEvent[] @relation("ScanCorrections")

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([cardId, createdAt])
  @@index([source, status])
  @@index([name])
  @@index([sessionHash, createdAt])
  @@index([correctionOfId, createdAt])
}

model CronRun {
  id         String        @id @default(cuid())
  job        String
  runKey     String
  status     CronRunStatus @default(RUNNING)
  startedAt  DateTime      @default(now())
  finishedAt DateTime?
  details    Json?
  error      String?
  createdAt  DateTime      @default(now())

  @@unique([job, runKey])
  @@index([job, startedAt])
  @@index([status])
  @@index([status, startedAt])
}

model FxRate {
  id        String   @id @default(cuid())
  quote     String
  perGbp    Float
  asOf      DateTime
  provider  String
  fetchedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([quote, asOf])
  @@index([asOf])
  @@index([fetchedAt])
}

// ─────────────────────────────────────────────────────────────
// Alerts / sourcing
// ─────────────────────────────────────────────────────────────

model Watch {
  id          String   @id @default(cuid())
  card        Card     @relation(fields: [cardId], references: [id])
  cardId      String
  grade       Grade    @default(RAW)
  targetPence Int // notify when market dips below this
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  alerts Alert[]

  @@index([active])
  @@unique([cardId, grade])
}

model Alert {
  id        String    @id @default(cuid())
  watch     Watch     @relation(fields: [watchId], references: [id])
  watchId   String
  kind      AlertKind
  message   String
  pence     Int?
  firedAt   DateTime  @default(now())
  delivered Boolean   @default(false)

  @@index([delivered])
}

model AppAlert {
  id        String       @id @default(cuid())
  kind      AppAlertKind
  title     String
  message   String
  pence     Int?
  href      String?
  sourceKey String?      @unique
  delivered Boolean      @default(false)
  readAt    DateTime?
  createdAt DateTime     @default(now())

  @@index([kind])
  @@index([readAt, createdAt])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum Game {
  POKEMON
  SOCCER // reserved for future (see brief §9)
}

enum Language {
  EN
  JP
}

enum Grade {
