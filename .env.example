# ─────────────────────────────────────────────────────────────
# Pokémon Dealer OS — environment
# Copy to .env and fill in. See README "Accounts & keys you need".
# ─────────────────────────────────────────────────────────────

# Postgres (local dev). With Docker: docker run --name pdos-db -e POSTGRES_PASSWORD=pdos -p 5432:5432 -d postgres
DATABASE_URL="postgresql://postgres:pdos@localhost:5432/pokemon_dealer_os?schema=public"
# In production, DATABASE_URL should be the pooled Neon endpoint and DIRECT_URL
# the matching unpooled endpoint. For local Postgres they may be identical.
DIRECT_URL="postgresql://postgres:pdos@localhost:5432/pokemon_dealer_os?schema=public"

# ── Comp data ────────────────────────────────────────────────
# Pokemon Price Tracker (primary comp source). Free tier to start: https://www.pokemonpricetracker.com/pricing
# Leave blank to mark the source unavailable. Fixtures are test-only and never become prices.
POKEMON_PRICE_TRACKER_API_KEY=""

# PokeTrace (secondary / cross-check). https://poketrace.com/docs
# The Free plan is personal/non-commercial, US/raw-only. The current deployment
# is owner-declared private use; re-audit and upgrade before any commercial use.
POKETRACE_API_KEY=""
# Free tier is US-only. Pro accounts can use "EU,US" for Cardmarket-first cross-checks.
POKETRACE_MARKETS="US"

# Pokémon TCG API (catalog, images, baseline prices). Free key: https://dev.pokemontcg.io
POKEMON_TCG_API_KEY=""

# PSA Public API (cert lookup). Free token via psacard.com account: https://www.psacard.com/publicapi
PSA_API_TOKEN=""

# ── eBay Sell / Inventory API ────────────────────────────────
# developer.ebay.com > Application keys. Used to push YOUR OWN listings.
# EBAY_ENV: "production" or "sandbox"
EBAY_ENV=production
EBAY_CLIENT_ID=""
EBAY_CLIENT_SECRET=""
# RuName from eBay Developer console (not the raw callback URL — it's the identifier string)
EBAY_RU_NAME=""
EBAY_MARKETPLACE_ID=EBAY_GB
# eBay REST header language for UK listing fields.
EBAY_CONTENT_LANGUAGE=en-GB
# Required for /api/ebay/connect to store the seller refresh token encrypted in the DB.
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=""
# Legacy fallback only. Normal flow is /api/ebay/connect, which stores the token in Neon.
EBAY_REFRESH_TOKEN=""
# Restricted API gate. Leave false until eBay grants Marketplace Insights access.
# When true, the comp engine tries UK eBay sold comps through Marketplace Insights.
EBAY_INSIGHTS_ENABLED=false
# Serverless instances enforce this locally, so keep below the provider's 5k/day
# Browse quota and use durable accounting before raising it.
EBAY_BROWSE_DAILY_LIMIT=500
# Required only when the production eBay app subscribes to marketplace account
# deletion. Must exactly match the 32-80 character token in the eBay dashboard.
EBAY_ACCOUNT_DELETION_VERIFICATION_TOKEN=""
# Optional: lets the app create the eBay Inventory API seller location for offer creation.
EBAY_MERCHANT_LOCATION_KEY=""
EBAY_LOCATION_NAME="Poke Deal"
EBAY_LOCATION_ADDRESS_LINE1=""
EBAY_LOCATION_ADDRESS_LINE2=""
EBAY_LOCATION_CITY=""
EBAY_LOCATION_STATE_OR_PROVINCE=""
EBAY_LOCATION_POSTAL_CODE=""
EBAY_LOCATION_COUNTRY=GB

# ── Listing photos ───────────────────────────────────────────
# Vercel Blob read/write token for inventory uploads and owned-blob deletion.
BLOB_READ_WRITE_TOKEN=""
# Catalog art can satisfy eBay photos for raw listings below this price.
# Above it, and for all graded slabs, real photos are required.
CATALOG_PHOTO_MAX_PRICE_GBP=20

# ── Alerts ───────────────────────────────────────────────────
# Discord webhook for price/repricing alerts. Server Settings → Integrations → Webhooks → New.
# ALERT_WEBHOOK_URL is a backwards-compatible alias but must also be a Discord URL.
DISCORD_WEBHOOK_URL=""
ALERT_WEBHOOK_URL=""

# ── FX ───────────────────────────────────────────────────────
# Optional live FX provider. Blank = use bundled static rates (fine for dev).
FX_API_KEY=""
# Optional override. freecurrencyapi's Free plan is non-commercial; use an
# entitled commercial provider for production dealer workflows. For
# freecurrencyapi hosts the key is sent in the documented `apikey` header and
# stripped from the URL; exchangeratesapi uses its `access_key` query contract.
FX_API_URL=""

# ── Auth gate (deploy) ───────────────────────────────────────
# Password for the HTTP Basic gate (src/middleware.ts). Blank is allowed only in
# local development/preview; production fails closed with 503. Configure this
# before deploying so the private dealer workspace never becomes public. Any
# username works; the password is the secret.
APP_PASSWORD=""
# Optional passwordless browser unlock. Both values must be independent random
# base64url/hex secrets of at least 32 bytes. The /access#TOKEN fragment is
# cleared before any request, then a signed Secure/HttpOnly session is issued.
# APP_PASSWORD must still be configured as the production fail-closed fallback.
APP_ACCESS_TOKEN=""
APP_SESSION_SECRET=""
NEXT_PUBLIC_APP_URL="https://poke-deal.vercel.app"

# Vercel cron authentication and bounded batch sizes.
CRON_SECRET=""
DAILY_CRON_LIMIT=10
WEEKLY_CRON_LIMIT=20
# Optional known cert used only by the read-only PSA health probe.
HEALTH_PSA_CERT=""

# Gemini — card image scanning (structured OCR for scan-to-comp). Verify the
# key type/restrictions in AI Studio before the September 2026 key migration.
# GEMINI_MODEL defaults to the stable, low-latency multimodal
# gemini-3.1-flash-lite model with minimal thinking for structured OCR.
GEMINI_API_KEY=
GEMINI_MODEL=
# Upstream request budget in milliseconds (safe range enforced: 1000-30000).
GEMINI_TIMEOUT_MS=12000
# Cost/fairness guards reset at 08:00 Europe/London. The daily limit is global;
# the session limit is per stable X-Poke-Deal-Session-Id (IP/UA fallback).
SCAN_DAILY_LIMIT=600
SCAN_SESSION_DAILY_LIMIT=120
# HMAC secret for session fingerprints; never store a device/session id directly.
# Generate a deployment-only value with: openssl rand -hex 32
SCAN_BUDGET_SECRET=""
