# ─────────────────────────────────────────────────────────────
# Pokémon Dealer OS — environment
# Copy to .env and fill in. See README "Accounts & keys you need".
# ─────────────────────────────────────────────────────────────

# Postgres (local dev). With Docker: docker run --name pdos-db -e POSTGRES_PASSWORD=pdos -p 5432:5432 -d postgres
DATABASE_URL="postgresql://postgres:pdos@localhost:5432/pokemon_dealer_os?schema=public"

# ── Comp data ────────────────────────────────────────────────
# Pokemon Price Tracker (primary comp source). Free tier to start: https://www.pokemonpricetracker.com/pricing
# Leave blank to run the app in FIXTURE mode (uses bundled sample data — great for the frame/demo).
POKEMON_PRICE_TRACKER_API_KEY=""

# PokeTrace (secondary / cross-check). https://poketrace.com/developers
POKETRACE_API_KEY=""
# Free tier is US-only. Pro accounts can use "EU,US" for Cardmarket-first cross-checks.
POKETRACE_MARKETS="US"

# Pokémon TCG API (catalog, images, baseline prices). Free key: https://dev.pokemontcg.io
POKEMON_TCG_API_KEY=""

# PSA Public API (cert lookup). Free token via psacard.com account: https://www.psacard.com/publicapi
PSA_API_TOKEN=""

# ── eBay Sell / Inventory API ────────────────────────────────
# developer.ebay.com > Application keys. Used to push YOUR OWN listings.
# EBAY_ENV: "production" or "sandbox"
EBAY_ENV=production
EBAY_CLIENT_ID=""
EBAY_CLIENT_SECRET=""
# RuName from eBay Developer console (not the raw callback URL — it's the identifier string)
EBAY_RU_NAME=""
EBAY_MARKETPLACE_ID=EBAY_GB
# eBay REST header language for UK listing fields.
EBAY_CONTENT_LANGUAGE=en-GB
# Set after completing OAuth at /api/ebay/connect. Expires ~18 months.
EBAY_REFRESH_TOKEN=""
# Restricted API gate. Leave false until eBay grants Marketplace Insights access.
# When true, the comp engine tries UK eBay sold comps through Marketplace Insights.
EBAY_MARKETPLACE_INSIGHTS_ENABLED=false
# Optional: lets the app create the eBay Inventory API seller location for offer creation.
EBAY_MERCHANT_LOCATION_KEY=""
EBAY_LOCATION_NAME="Poke Deal"
EBAY_LOCATION_ADDRESS_LINE1=""
EBAY_LOCATION_ADDRESS_LINE2=""
EBAY_LOCATION_CITY=""
EBAY_LOCATION_STATE_OR_PROVINCE=""
EBAY_LOCATION_POSTAL_CODE=""
EBAY_LOCATION_COUNTRY=GB

# ── Alerts ───────────────────────────────────────────────────
# Discord webhook for price/repricing alerts. Server Settings → Integrations → Webhooks → New.
DISCORD_WEBHOOK_URL=""

# ── FX ───────────────────────────────────────────────────────
# Optional live FX provider. Blank = use bundled static rates (fine for dev).
FX_API_KEY=""
# Optional override for providers that use the same "base GBP, symbols" shape.
FX_API_URL=""

# ── Auth gate (deploy) ───────────────────────────────────────
# Password for the HTTP Basic gate (src/middleware.ts). BLANK = gate disabled (local dev).
# Set this in your Vercel env so the deployed app isn't public. Any username works.
APP_PASSWORD=""
